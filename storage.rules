rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isBusinessMember(businessId) {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/businesses/$(businessId)/members/$(request.auth.uid));
    }

    function isImage() {
      return request.resource.contentType.matches('image/.*') &&
        request.resource.size < 5 * 1024 * 1024;
    }

    match /users/{userId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == userId && isImage();
    }

    match /businesses/{businessId}/receipts/{fileName} {
      allow read: if isBusinessMember(businessId);
      allow write: if isBusinessMember(businessId) && isImage();
    }
  }
}
